{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/devxoul/opencode-disabler/main/schema.json",
  "title": "opencode-disabler Configuration",
  "description": "Configuration schema for opencode-disabler plugin",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "plugins": {
      "type": "array",
      "description": "Plugin package names to disable",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "skills": {
      "type": "array",
      "description": "Skill names to disable",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
