{
  "name": "opencode-disabler",
  "version": "1.1.0",
  "type": "module",
  "main": "src/index.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/devxoul/opencode-disabler"
  },
  "scripts": {
    "build": "tsc && tsc-alias --resolve-full-paths",
    "postbuild": "bun scripts/postbuild.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "prepublishOnly": "bun run build && bun scripts/prepublish.ts",
    "postpublish": "git checkout package.json"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "oxfmt": "^0.38.0",
    "oxlint": "^1.53.0",
    "tsc-alias": "latest",
    "typescript": "latest"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.2.24"
  }
}
